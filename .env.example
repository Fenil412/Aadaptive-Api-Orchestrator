# ============================================================
# RL API Orchestration System — Environment Configuration
# Copy this file to backend/.env and fill in your values.
# ============================================================

# ── Database ────────────────────────────────────────────────
# SQLite (default, no setup required):
DATABASE_URL=sqlite+aiosqlite:///./api_orchestrator.db

# PostgreSQL / Supabase (recommended for production):
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── Application ─────────────────────────────────────────────
PROJECT_NAME=RL API Orchestration
APP_ENV=development
LOG_LEVEL=INFO

# ── RL Model ────────────────────────────────────────────────
# Path to the trained PPO model .zip file (relative to backend/)
RL_MODEL_PATH=models/ppo_api_orchestrator.zip
MODEL_PATH=models/ppo_api_orchestrator.zip

# ── CORS ────────────────────────────────────────────────────
# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── API Key (optional) ──────────────────────────────────────
# Leave empty to disable authentication
API_KEY=

# ── Frontend (Vite) ─────────────────────────────────────────
# Set this in frontend/.env
VITE_API_BASE_URL=http://localhost:8000
